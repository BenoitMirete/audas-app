{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@audas/shared": ["../../packages/shared/src/index.ts"]
    },
    "noEmit": true
  },
  "include": ["src", "vitest.setup.ts"],
  "exclude": ["node_modules", "dist"]
}
